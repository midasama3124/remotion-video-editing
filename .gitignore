.DS_Store
.cache/
.remotion/

# Python bytecode/cache (anywhere in repo)
__pycache__/
*.py[cod]
*$py.class

# Ignore media files outside assets/
*.webm
*.mp4
*.mov
*.mkv
*.avi
*.m4v
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg
*.mp3
*.wav
*.m4a
*.aac
*.flac
*.ogg

# Keep media files under assets/
!assets/**/*.webm
!assets/**/*.mp4
!assets/**/*.mov
!assets/**/*.mkv
!assets/**/*.avi
!assets/**/*.m4v
!assets/**/*.png
!assets/**/*.jpg
!assets/**/*.jpeg
!assets/**/*.gif
!assets/**/*.webp
!assets/**/*.svg
!assets/**/*.mp3
!assets/**/*.wav
!assets/**/*.m4a
!assets/**/*.aac
!assets/**/*.flac
!assets/**/*.ogg
